# Copy to `.env` and fill in. The app auto-loads .env (python-dotenv).

# --- LLM extraction (LiteLLM provider string + key) ---
# Pick ONE provider and set its key. Both OpenAI and OpenRouter are supported.
#
# OpenRouter (default): cheap, reliable.
CFP_LLM_PROVIDER=openrouter/deepseek/deepseek-chat
OPENROUTER_API_KEY=sk-or-your-key-here
#
# OpenAI instead — just switch the provider and set the OpenAI key:
# CFP_LLM_PROVIDER=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-your-openai-key-here
#
# Or run fully local & free (no key needed):
# CFP_LLM_PROVIDER=ollama/qwen2.5-coder:14b

# --- Licensed customer build (Option D): route LLM through the vendor proxy, no provider key here ---
# When these two are set, the app requires a license (not a provider key) and all extraction goes
# through your proxy. Leave BLANK for developer / vendor builds.
# CFP_LLM_PROXY_URL=https://license.yourco.com
# CFP_LICENSE_KEY=cfp_xxxxxxxx

# --- Crawl budget / boundaries (per conference) ---
CFP_MAX_DEPTH=2
CFP_MAX_PAGES=12
CFP_MAX_EXTRACT_PAGES=8
CFP_INCLUDE_EXTERNAL=false
CFP_SITE_TIMEOUT_S=180

# --- LLM tuning ---
CFP_LLM_TEMPERATURE=0.0
CFP_LLM_MAX_TOKENS=1400

# --- Behaviour ---
CFP_HEADLESS=true
CFP_VERBOSE=false
