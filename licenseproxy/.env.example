# VENDOR proxy config. Copy to licenseproxy/.env (or export these) before running the proxy.
# This is the ONLY place a real LLM provider key lives — it never ships to customers.

# Where the license keys live (created via `python -m licenseproxy.admin`).
LICENSE_DB=licenses.db

# The model the proxy uses for every customer (customers can't pick an expensive one).
# OpenRouter:
PROXY_MODEL=openrouter/deepseek/deepseek-chat
OPENROUTER_API_KEY=sk-or-your-vendor-key

# ...or OpenAI instead (set the model to openai/* and provide the OpenAI key):
# PROXY_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-your-openai-vendor-key

# Optional: require a feature entitlement on the completions endpoint (e.g. "crawl").
# PROXY_FEATURE=crawl
